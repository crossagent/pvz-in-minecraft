{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.zombies": {
			"initial_state": "idle",
			"states": {
				"idle": {
					"animations": [
						"idle"
					],
					"transitions": [
						{
							"walking": "query.ground_speed"
						},
						{
							"attacking": "variable.has_target && variable.attack_time >= 0.1"
						},
						{
							"dead": "query.mark_variant == 1"
						}
					],
					"blend_transition": 0.1
				},
				"walking": {
					"animations": [
						"walk"
					],
					"transitions": [
						{
							"idle": "!query.ground_speed"
						},
						{
							"attacking": "query.any_animation_finished && variable.has_target && variable.attack_time >= 0.1"
						},
						{
							"dead": "query.mark_variant == 1"
						}
					],
					"blend_transition": 0.1
				},
				"attacking": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"idle": "query.any_animation_finished && variable.attack_time <= 0.0 && !query.ground_speed"
						},
						{
							"walking": "variable.attack_time <= 0.0 && query.ground_speed"
						},
						{
							"dead": "query.mark_variant == 1"
						}
					],
					"blend_transition": 0.1
				},
				"dead": {
					"animations": [
						"death"
					]
				}
			}
		}
	}
}